#!/usr/bin/env bash
set -euo pipefail

MNT="/mnt/usb"
LABEL="USB"

API_BASE="${API_BASE:-http://middleware:8080}"
API_TOKEN="${API_TOKEN:-}"
INTENT_ID="${1:-}"

die(){ echo "ERROR: $*" >&2; exit 1; }
info(){ echo "[*] $*"; }

[[ $EUID -eq 0 ]] || die "Bitte als root ausführen."
[[ -n "$INTENT_ID" ]] || die "Usage: $0 <intent-id>"

DEV="$(readlink -f /dev/disk/by-label/${LABEL} 2>/dev/null || true)"
[[ -n "$DEV" ]] || die "Kein Device mit Label '${LABEL}' gefunden."

mkdir -p "$MNT"
mountpoint -q "$MNT" || mount "$DEV" "$MNT"

mkdir -p "$MNT/psbt" "$MNT/psbt/auth" "$MNT/psbt/archive"

shopt -s nullglob
existing=( "$MNT/psbt"/unappr.*.psbt )
shopt -u nullglob
[[ ${#existing[@]} -eq 0 ]] || die "USB enthält bereits unappr.*.psbt (Single-TX Regel verletzt): ${existing[*]}"

curl_api(){
  local url="$1"
  if [[ -n "$API_TOKEN" ]]; then
    curl -fsSL -H "Authorization: Bearer $API_TOKEN" "$url"
  else
    curl -fsSL "$url"
  fi
}

TMP="$(mktemp)"
trap 'rm -f "$TMP" 2>/dev/null || true' EXIT

URL="${API_BASE}/api/v1/intents/${INTENT_ID}/psbt?format=base64"
info "Fetch PSBT base64: $URL"

b64="$(curl_api "$URL" | jq -r '.psbt_base64')" || die "PSBT fetch/parse failed."
[[ -n "$b64" && "$b64" != "null" ]] || die "Empty psbt_base64."

echo "$b64" | base64 -d > "$TMP" || die "base64 decode failed."

ts="$(date -u +%Y%m%d-%H%M%S)"
hash="$(sha256sum "$TMP" | awk '{print $1}')"
id="${ts}-${hash:0:12}"

OUT="$MNT/psbt/unappr.${id}.psbt"
cp -f "$TMP" "$OUT"

info "Wrote: psbt/unappr.${id}.psbt"
info "sha256: $hash"

sync
umount "$MNT"
info "USB unmounted: $MNT"
info "Jetzt am Proxmox Host: ENTER zum Detach."