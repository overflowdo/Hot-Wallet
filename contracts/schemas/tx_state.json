{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TxState",
  "type": "object",
  "required": ["id", "state", "updated_utc"],
  "properties": {
    "id": { "type": "string" },
    "state": {
      "type": "string",
      "enum": ["CREATED", "APPROVED", "SIGNED", "BROADCAST", "CONFIRMED", "FAILED"]
    },
    "updated_utc": { "type": "string" },
    "txid": { "type": "string" },
    "error": { "type": "string" },
    "meta": { "type": "object" }
  }
}